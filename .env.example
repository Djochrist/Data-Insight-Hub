# Local dev (Node/Express)
PORT=5000
NODE_ENV=development

# Production (Vercel) — for persistence
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Optional: protect write/delete operations (POST/DELETE) with a Bearer token.
# If empty, the API is public (not recommended for a public deployment).
# ADMIN_TOKEN=replace-with-a-long-random-token

